# SSL Verification Configuration
# SSL 证书路径（留空表示使用系统默认 CA 证书）
SSL_CERT_PATH=
# 是否启用 SSL 证书验证（true/false）
SSL_VERIFY=false

# Logging
LOG_LEVEL=INFO

# API Rate Limit Configuration
# API 限流最大请求数（窗口期内允许的最大请求次数）
RATE_LIMIT_MAX_REQUESTS=60
# API 限流窗口时长（单位：秒）
RATE_LIMIT_WINDOW_SECONDS=60

# MCP Authentication Configuration
# MCP_AUTH_ENABLED=true 时，认证方式由 MCP_AUTH_MODE 决定:
#   - oauth:     OAuth 2.1 授权码流程（需配置 MCP_OAUTH_USERS）
#   - api_key:   MCP_AUTH_MODE 和 MCP_JWT_MODE 共同决定验证方式（默认）
MCP_AUTH_ENABLED=false
MCP_AUTH_MODE=api_key
MCP_AUTH_API_KEY=your-secret-api-key-here
MCP_SERVER_BASE_URL=http://localhost:8082
MCP_ALLOWED_ORIGINS=http://localhost:8082,http://localhost:3000
MCP_OAUTH_USERS=admin:password123,user:password456

# JWT Verification Configuration
# MCP_AUTH_MODE=api_key 时生效，MCP_JWT_MODE 支持四种模式:
#   1. api_key:     简单字符串比对（默认，兼容旧版）
#   2. jwks:        从 JWKS 端点获取公钥验证（自动密钥轮换）
#   3. public_key:  使用静态 RSA/ECDSA 公钥验证
#   4. hmac:        使用共享密钥（HMAC）验证
MCP_JWT_MODE=api_key
#MCP_JWKS_URI=https://auth.example.com/.well-known/jwks.json
#MCP_JWT_ISSUER=https://auth.example.com
#MCP_JWT_AUDIENCE=mcp-server
#MCP_JWT_ALGORITHM=RS256
#MCP_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...
#MCP_JWT_SECRET=your-hmac-shared-secret
